  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set variables from login responses",
          "const pmBody = pm.request.body?.raw;",
          "if (pm.request.url.toString().includes('/auth/login')) {",
          "  pm.variables.set('loginBody', pmBody);",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-capture tokens from login responses",
          "const jsonData = pm.response.json();",
          "if (jsonData?.data?.accessToken) {",
          "  const email = JSON.parse(pm.variables.get('loginBody') || '{}')?.email;",
          "  if (email?.includes('admin')) pm.collectionVariables.set('adminToken', jsonData.data.accessToken);",
          "  else if (email?.includes('tech')) pm.collectionVariables.set('technicianToken', jsonData.data.accessToken);",
          "  else pm.collectionVariables.set('customerToken', jsonData.data.accessToken);",
          "}",
          "",
          "// Auto-capture IDs from responses",
          "if (jsonData?.data?.id) {",
          "  const url = pm.request.url.toString();",
          "  if (url.includes('/services')) pm.collectionVariables.set('serviceId', jsonData.data.id);",
          "  if (url.includes('/bookings')) pm.collectionVariables.set('bookingId', jsonData.data.id);",
          "}",
          "if (jsonData?.data?.gatewayUrl) {",
          "  pm.collectionVariables.set('gatewayUrl', jsonData.data.gatewayUrl);",
          "}"
        ]
      }
    }
  ],
